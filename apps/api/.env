# ===========================================
# SERVER CONFIGURATION
# ===========================================
NODE_ENV=development
PORT=3000
API_PREFIX=/api

# ===========================================
# DATABASE (MySQL)
# ===========================================
DATABASE_URL="mysql://root:@localhost:3306/nodewave_db"

# ===========================================
# REDIS (Bull Queue)
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===========================================
# JWT AUTHENTICATION
# ===========================================
JWT_SECRET=nodewave-assessment-secret-key-123456
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=nodewave-assessment-refresh-secret-key

# ===========================================
# FILE UPLOAD (Local Storage)
# ===========================================
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=debug
LOG_DIR=./logs
